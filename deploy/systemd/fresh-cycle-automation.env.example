# SC-node fresh-cycle payout automation — baseline-gated, no historical backlog.
# Copy to /etc/azcoin-super/pool-ledger/fresh-cycle-automation.env (root:azledger 0640).

# Automation baseline (Cycle #4 confirmed completion). Never select rewards before this time.
AZCOIN_FRESH_CYCLE_AUTOMATION_BASELINE=2026-05-28T14:50:30+00:00

# preview | write-target | execute-live
# Timer default should remain write-target until live policy is deliberately enabled.
AZCOIN_FRESH_CYCLE_AUTOMATION_MODE=write-target

AZCOIN_FRESH_CYCLE_AUTOMATION_WALLET=wallet
AZCOIN_FRESH_CYCLE_AUTOMATION_RESERVE_FRACTION=0.50
AZCOIN_FRESH_CYCLE_AUTOMATION_TARGET_SINGLE_TX_MAX_AMOUNT=500
AZCOIN_FRESH_CYCLE_AUTOMATION_FALLBACK_CHUNK_AMOUNT=25
AZCOIN_FRESH_CYCLE_AUTOMATION_AZC_BIN=/usr/local/bin/azc-payout-readonly
AZCOIN_FRESH_CYCLE_AUTOMATION_APPROVED_BY=fresh-cycle-automation

# execute-live only (never enable on timer until reviewed):
# AZCOIN_FRESH_CYCLE_AUTOMATION_ENABLE_REAL_EXECUTION=YES_ENABLE_FRESH_CYCLE_AUTOMATION
# AZCOIN_FRESH_CYCLE_AUTOMATION_RUNNER_APPROVAL_PHRASE=YES_I_APPROVE_PERIODIC_SC_NODE_PAYOUT

# Optional minimum payout threshold; below this preview/write-target halts with explicit refusal_reason.
# AZCOIN_FRESH_CYCLE_AUTOMATION_MIN_PAYOUT_AMOUNT=10

# AZCOIN_FRESH_CYCLE_AUTOMATION_ON_CALENDAR=*:0/30
