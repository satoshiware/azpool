# SC-node payout scheduler v0 — explicit-target manual-approved automation.
# Copy to /etc/azcoin-super/pool-ledger/payout-scheduler.env (root:azledger 0660).
# Leave target IDs unset to keep timer wake-ups as SAFE_SKIP (exit 0, no sends).
# DATABASE_URL is inherited from collector.env via the service unit.

# Safe default for fresh installs and existing-node report-only posture:
SC_NODE_PAYOUT_SCHEDULER_MODE=report-only

# --- explicit approved target (all three required to act) ---
# SC_NODE_PAYOUT_SCHEDULER_PAYOUT_PLAN_ID=2
# SC_NODE_PAYOUT_SCHEDULER_PRODUCTION_PREFLIGHT_ID=2
# SC_NODE_PAYOUT_SCHEDULER_RECOMMENDED_EXECUTION_MODE=chunked

# --- delegate / execute-enabled only (never enable unattended sends without review) ---
# SC_NODE_PAYOUT_SCHEDULER_RUNNER_APPROVAL_PHRASE=YES_I_APPROVE_PERIODIC_SC_NODE_PAYOUT
# SC_NODE_PAYOUT_SCHEDULER_EXECUTOR_CONFIRM_PHRASE='SEND CHUNKED ... FROM wallet FOR PLAN ...'
# SC_NODE_PAYOUT_SCHEDULER_SOURCE_WALLET_NAME=wallet
# SC_NODE_PAYOUT_SCHEDULER_IDEMPOTENCY_KEY=production-chunked-v0-plan-2
# SC_NODE_PAYOUT_SCHEDULER_CHUNK_AMOUNT=25

# --- timer install helper (used by install script, not read by scheduler at runtime) ---
# SC_NODE_PAYOUT_SCHEDULER_ON_CALENDAR='Mon *-*-* 09:00:00'
