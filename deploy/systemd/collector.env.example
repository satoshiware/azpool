# Pool ledger collector — SC-node support services (root:azledger 0640).
# Fresh installs: set DATABASE_URL before enabling collector timer.
# Never commit real credentials to Git.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional fallback when pool_instances DB registry is empty:
# POOL_INSTANCES=[{"id":"pool01","base_url":"http://10.10.70.131:9090"}]

# COLLECTOR_REQUEST_TIMEOUT_SECONDS=10
